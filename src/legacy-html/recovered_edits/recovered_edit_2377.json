  "ReplacementContent": "                        <!-- Right Section: Retained Students Selection -->\n                        <div style=\"background: var(--white); border: 1px solid var(--border); border-radius: 8px; padding: 15px; display: flex; flex-direction: column; gap: 12px;\">\n                            <h5 style=\"margin: 0; font-size: 0.9rem; font-weight: 600; color: var(--text-main); display: flex; align-items: center; justify-content: space-between;\">\n                                <span style=\"display: flex; align-items: center; gap: 6px;\"><i class=\"fa-solid fa-user-slash\" style=\"color: var(--danger);\"></i> ตรวจสอบผู้เรียนที่ \"ซ้ำชั้น\" (Retained)</span>\n                                <span style=\"font-size: 0.75rem; font-weight: normal; color: var(--text-muted);\">* จะไม่มีการเลื่อนชั้นปี</span>\n                            </h5>\n                            \n                            <!-- Search & Filter Controls -->\n                            <div style=\"display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 10px; background: var(--secondary); padding: 10px; border-radius: 8px; border: 1px solid var(--border);\">\n                                <!-- Search Input -->\n                                <div style=\"position: relative; display: flex; align-items: center;\">\n                                    <i class=\"fa-solid fa-magnifying-glass\" style=\"position: absolute; left: 10px; color: var(--text-muted); font-size: 0.8rem;\"></i>\n                                    <input type=\"text\" id=\"retained-search-input\" oninput=\"filterRetainedStudents()\" placeholder=\"ค้นหาชื่อ หรือรหัสนักเรียน...\" style=\"width: 100%; padding: 6px 10px 6px 28px; font-size: 0.82rem; border: 1px solid var(--border); border-radius: 6px; outline: none; background: var(--white); color: var(--text-main); transition: border-color 0.2s;\" onfocus=\"this.style.borderColor='var(--primary)'\" onblur=\"this.style.borderColor='var(--border)'\">\n                                </div>\n                                <!-- Grade Filter Dropdown -->\n                                <select id=\"retained-filter-grade\" onchange=\"filterRetainedStudents()\" style=\"padding: 6px 10px; font-size: 0.82rem; border: 1px solid var(--border); border-radius: 6px; outline: none; background: var(--white); color: var(--text-main); cursor: pointer; transition: border-color 0.2s;\" onfocus=\"this.style.borderColor='var(--primary)'\" onblur=\"this.style.borderColor='var(--border)'\">\n                                    <option value=\"all\">ทุกระดับชั้น (ทั้งหมด)</option>\n                                    <option value=\"m3\">ชั้น ม.3</option>\n                                    <option value=\"m2\">ชั้น ม.2</option>\n                                    <option value=\"m1\">ชั้น ม.1</option>\n                                </select>\n                                <!-- Room Filter Dropdown -->\n                                <select id=\"retained-filter-room\" onchange=\"filterRetainedStudents()\" style=\"padding: 6px 10px; font-size: 0.82rem; border: 1px solid var(--border); border-radius: 6px; outline: none; background: var(--white); color: var(--text-main); cursor: pointer; transition: border-color 0.2s;\" onfocus=\"this.style.borderColor='var(--primary)'\" onblur=\"this.style.borderColor='var(--border)'\">\n                                    <option value=\"all\">ทุกห้องเรียน (ทั้งหมด)</option>\n                                    <option value=\"1\">ห้อง 1</option>\n                                    <option value=\"2\">ห้อง 2</option>\n                                    <option value=\"3\">ห้อง 3</option>\n                                </select>\n                            </div>\n\n                            <!-- Selected Summary Container -->\n                            <div id=\"retained-selected-summary\" style=\"display: none; background: rgba(14, 165, 233, 0.03); border: 1px dashed var(--primary); border-radius: 8px; padding: 10px; flex-direction: column; gap: 8px;\">\n                                <div style=\"display: flex; align-items: center; justify-content: space-between; font-size: 0.8rem; font-weight: 600; color: var(--primary-dark);\">\n                                    <span style=\"display: flex; align-items: center; gap: 6px;\"><i class=\"fa-solid fa-circle-check\" style=\"color: var(--primary);\"></i> รายชื่อนักเรียนซ้ำชั้นที่เลือกไว้ (<span id=\"retained-selected-count\">0</span> คน)</span>\n                                    <button type=\"button\" onclick=\"clearAllRetainedSelections()\" style=\"background: none; border: none; color: var(--danger); font-size: 0.75rem; cursor: pointer; padding: 0; font-weight: 600; text-decoration: underline;\">✕ ล้างทั้งหมด</button>\n                                </div>\n                                <div id=\"retained-selected-tags\" style=\"display: flex; flex-wrap: wrap; gap: 6px; max-height: 80px; overflow-y: auto; padding-right: 4px;\">\n                                    <!-- Selected students tags go here -->\n                                </div>\n                            </div>\n                            \n                            <!-- Student List Container -->\n                            <div id=\"retained-list-container\" style=\"max-height: 380px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; padding-right: 4px; font-size: 0.85rem; border: 1px solid var(--border); border-radius: 6px; padding: 10px; background: var(--bg-main);\">\n                                <!-- Dynamic list of students with checkboxes -->\n                            </div>\n                        </div>",
  "StartLine": 1798,
