  "ReplacementContent": "                let attachmentsHtml = '';\n                if (item.attachments && item.attachments.length > 0) {\n                    attachmentsHtml += `\n                        <div class=\"assignment-attachments-container\">\n                            <span class=\"assignment-attachments-label\">เอกสารประกอบ:</span>\n                            <div class=\"assignment-attachments-list\">\n                    `;\n                    item.attachments.forEach(file => {\n                        const icon = getFileIcon(file.type, file.name);\n                        attachmentsHtml += `\n                            <a href=\"javascript:void(0)\" onclick=\"downloadAttachmentFile('${item.id}', '${file.id}')\" class=\"attachment-file-card\" title=\"${file.name}\">\n                                <i class=\"${icon}\"></i>\n                                <span style=\"white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 180px;\">${file.name}</span>\n                                <span class=\"attachment-file-size\">(${formatBytes(file.size)})</span>\n                            </a>\n                        `;\n                    });\n                    attachmentsHtml += `\n                            </div>\n                        </div>\n                    `;\n                }\n\n                html += `\n                    <div class=\"assignment-card status-${statusKey}\">\n                        <!-- Header: Title, Class & Action Buttons -->\n                        <div class=\"assignment-card-header\">\n                            <div class=\"assignment-card-title-group\">\n                                <h4 class=\"assignment-card-title\">${item.title}</h4>\n                                <span class=\"assignment-card-class-badge\">${formatClassLabel(item.class)}</span>\n                            </div>\n                            <div class=\"assignment-card-actions\">\n                                <button class=\"btn-action-edit\" onclick=\"openAssignmentModal('${item.id}')\" title=\"แก้ไข\">\n                                    <i class=\"fa-regular fa-pen-to-square\"></i> <span class=\"btn-text\">แก้ไข</span>\n                                </button>\n                                <button class=\"btn-action-delete\" onclick=\"deleteAssignment('${item.id}')\" title=\"ลบ\">\n                                    <i class=\"fa-regular fa-trash-can\"></i> <span class=\"btn-text\">ลบ</span>\n                                </button>\n                            </div>\n                        </div>\n\n                        <!-- Description -->\n                        <div class=\"assignment-card-description\">\n                            ${item.description || '<span style=\"color:#cbd5e1; font-style:italic;\">- ไม่มีคำอธิบายเพิ่มเติม -</span>'}\n                        </div>\n\n                        <!-- Attachments -->\n                        ${attachmentsHtml}\n\n                        <!-- Divider line -->\n                        <hr class=\"assignment-card-divider\" />\n\n                        <!-- Footer Stats & Status Info -->\n                        <div class=\"assignment-card-footer\">\n                            <div class=\"assignment-card-stats\">\n                                <span class=\"assignment-stat-item\">\n                                    <i class=\"fa-regular fa-calendar\" style=\"color:var(--text-muted); font-size:0.9rem;\"></i>\n                                    กำหนดส่ง: <strong style=\"color:var(--text-main);\">${dueLabel}</strong>\n                                </span>\n                                <span class=\"assignment-stat-item\">\n                                    <i class=\"fa-solid fa-users\" style=\"color:var(--text-muted); font-size:0.85rem;\"></i>\n                                    ส่งการบ้านแล้ว: <strong style=\"color:var(--text-main);\">${submissions} คน</strong>\n                                </span>\n                            </div>\n                            <span class=\"assignment-status-badge ${statusKey}\">\n                                ${status}\n                            </span>\n                        </div>\n                    </div>\n                `;",
