stify-content:space-between; align-items:flex-start; gap:14px; background: var(--white); border:1px solid rgba(148,163,184,0.18); padding:18px; border-radius:20px; box-shadow: var(--shadow-sm);\">\n                        <div style=\"flex:1; min-width:0;\">\n                            <div style=\"display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:10px;\">\n                                <div style=\"font-size:1rem; font-weight:700; color: var(--text-main);\">${item.title}</div>\n                                <span style=\"font-size:0.82rem; color: var(--text-muted);\">${formatClassLabel(item.class)}</span>\n                            </div>\n                            <div style=\"font-size:0.92rem; color: var(--text-muted); line-height:1.6; min-height:52px;\">${item.description || '<span style=\\\"color:var(--border);\\\">- ไม่มีคำอธิบายเพิ่มเติม -</span>'}</div>\n                            ${attachmentsHtml}\n                            <div style=\"margin-top:14px; display:flex; flex-wrap:wrap; gap:10px; color: var(--text-muted); font-size:0.82rem; align-items:center;\">\n                                <span>กำหนดส่ง: <strong style=\"color: var(--text-main);\">${dueLabel}</strong></span>\n                                <span>ส่งแล้ว: <strong>${submissions}</strong></span>\n                                <span style=\"padding:6px 10px; border-radius:999px; background:${statusBg}; color:${statusColor}; font-weight:700;\">${status}</span>\n                            </div>\n                        </div>\n                        <div style=\"display:flex; flex-direction:column; gap:10px; flex-shrink:0; align-items:flex-end;\">\n                            <button class=\"btn-action\" onclick=\"openAssignmentModal('${item.id}')\">แก้ไข</button>\n                            <button class=\"btn-action\" style=\"background: var(--danger-bg); color: var(--danger-text); border: 1px solid var(--danger-border);\" onclick=\"deleteAssignment('${item.id}')\">ลบ</button>\n                        </div>\n                    </div>\n                `;",
