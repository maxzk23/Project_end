  "ReplacementContent": "                let attachmentsHtml = '';\n                if (item.attachments && item.attachments.length > 0) {\n                    attachmentsHtml += `\n                        <div style=\"margin-top: 12px; display: flex; flex-direction: column; gap: 6px; margin-bottom: 4px;\">\n                            <span style=\"font-size: 0.8rem; font-weight: 600; color: var(--text-main);\">เอกสารประกอบ:</span>\n                            <div style=\"display: flex; flex-wrap: wrap; gap: 8px;\">\n                    `;\n                    item.attachments.forEach(file => {\n                        const icon = getFileIcon(file.type, file.name);\n                        attachmentsHtml += `\n                            <a href=\"javascript:void(0)\" onclick=\"downloadAttachmentFile('${item.id}', '${file.id}')\" style=\"display: inline-flex; align-items: center; gap: 6px; font-size: 0.78rem; background: var(--secondary); border: 1px solid var(--border); padding: 5px 10px; border-radius: 8px; color: var(--primary); text-decoration: none; font-weight: 500; transition: all 0.2s;\" onmouseover=\"this.style.borderColor='var(--primary)'; this.style.background='var(--white)';\" onmouseout=\"this.style.borderColor='var(--border)'; this.style.background='var(--secondary)';\">\n                                <i class=\"${icon}\"></i>\n                                <span style=\"white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 180px;\">${file.name}</span>\n                                <span style=\"color: var(--text-muted); font-size: 0.7rem; font-weight: normal; flex-shrink: 0;\">(${formatBytes(file.size)})</span>\n                            </a>\n                        `;\n                    });\n                    attachmentsHtml += `\n                            </div>\n                        </div>\n                    `;\n                }\n\n                html += `\n                    <div style=\"display:flex; justify-content:space-between; align-items:flex-start; gap:14px; background: var(--white); border:1px solid rgba(148,163,184,0.18); padding:18px; border-radius:20px; box-shadow: var(--shadow-sm);\">\n                        <div style=\"flex:1; min-width:0;\">\n                            <div style=\"display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:10px;\">\n                                <div style=\"font-size:1rem; font-weight:700; color: var(--text-main);\">${item.title}</div>\n                                <span style=\"font-size:0.82rem; color: var(--text-muted);\">${formatClassLabel(item.class)}</span>\n                            </div>\n                            <div style=\"font-size:0.92rem; color: var(--text-muted); line-height:1.6; min-height:52px;\">${item.description || '<span style=\\\"color:var(--border);\\\">- ไม่มีคำอธิบายเพิ่มเติม -</span>'}</div>\n                            ${attachmentsHtml}\n                            <div style=\"margin-top:14px; display:flex; flex-wrap:wrap; gap:10px; color: var(--text-muted); font-size:0.82rem; align-items:center;\">\n                                <span>กำหนดส่ง: <strong style=\"color: var(--text-main);\">${dueLabel}</strong></span>\n                                <span>ส่งแล้ว: <strong>${submissions}</strong></span>\n                                <span style=\"padding:6px 10px; border-radius:999px; background:${statusBg}; color:${statusColor}; font-weight:700;\">${status}</span>\n                            </div>\n                        </div>\n                        <div style=\"display:flex; flex-direction:column; gap:10px; flex-shrink:0; align-items:flex-end;\">\n                            <button class=\"btn-action\" onclick=\"openAssignmentModal('${item.id}')\">แก้ไข</button>\n                            <button class=\"btn-action\" style=\"background: var(--danger-bg); color: var(--danger-text); border: 1px solid var(--danger-border);\" onclick=\"deleteAssignment('${item.id}')\">ลบ</button>\n                        </div>\n                    </div>\n                `;",
